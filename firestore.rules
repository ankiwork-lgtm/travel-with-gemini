rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /conversation_memory/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
